---
---

<section class="section contact-section" id="contact">
  <div class="contact-particles" id="contactParticles">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
    <div class="particle particle-6"></div>
    <div class="particle particle-7"></div>
    <div class="particle particle-8"></div>
    <div class="particle particle-9"></div>
    <div class="particle particle-10"></div>
  </div>

  <div class="container">
    <div class="text-center mb-5">
      <span class="section-tag" id="contactTag">CONTACT</span>
      <h2 class="section-title contact-title" id="contactTitle">Let's Work Together</h2>
      <p class="section-subtitle contact-subtitle" id="contactSubtitle">
        Have a project in mind? Let's create something amazing.
      </p>
    </div>

    <div class="contact-container">
      <div class="contact-info-card" data-tilt>
        <div class="contact-glow"></div>
        
        <div class="contact-header">
          <div class="contact-avatar">
            <i class="bi bi-person-circle"></i>
          </div>
          <h3>Nitesh Kumar Verma</h3>
          <p>BCA Student</p>
        </div>

        <div class="availability-badge" id="availabilityBadge">
          <span class="pulse-dot"></span>
          <span class="availability-text">Open to Work</span>
        </div>

        <div class="contact-methods">
          <div class="contact-method" onclick="copyContactEmail('nitesh.techcollab@gmail.com', this)">
            <div class="method-icon">
              <i class="bi bi-envelope-fill"></i>
            </div>
            <div class="method-info">
              <span class="method-label">Email</span>
              <span class="method-value" id="contactEmail">nitesh.techcollab@gmail.com</span>
            </div>
            <div class="method-action">
              <i class="bi bi-clipboard" id="copyIcon"></i>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">
              <i class="bi bi-geo-alt-fill"></i>
            </div>
            <div class="method-info">
              <span class="method-label">Location</span>
              <span class="method-value">Bangalore, India</span>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">
              <i class="bi bi-clock-fill"></i>
            </div>
            <div class="method-info">
              <span class="method-label">Response Time</span>
              <span class="method-value">Usually within 24 hours</span>
            </div>
          </div>
        </div>

        <div class="contact-social-section">
          <span class="social-label">Connect With Me</span>
          <div class="contact-social-links" id="contactSocialLinks">
            <a href="https://github.com/nkv-dev" target="_blank" class="contact-social-link github" data-social="github" title="GitHub" aria-label="GitHub">
              <i class="bi bi-github"></i>
              <span class="tooltip">GitHub</span>
            </a>
            <a href="https://www.linkedin.com/in/nitesh-kumar-verma-408249334/" target="_blank" class="contact-social-link linkedin" data-social="linkedin" title="LinkedIn" aria-label="LinkedIn">
              <i class="bi bi-linkedin"></i>
              <span class="tooltip">LinkedIn</span>
            </a>
            <a href="https://x.com/nkv_dev" target="_blank" class="contact-social-link twitter" data-social="twitter" title="X (Twitter)" aria-label="Twitter">
              <i class="bi bi-twitter-x"></i>
              <span class="tooltip">X (Twitter)</span>
            </a>
            <a href="mailto:nitesh.techcollab@gmail.com" class="contact-social-link email" data-social="email" title="Email" aria-label="Email">
              <i class="bi bi-envelope-fill"></i>
              <span class="tooltip">Email</span>
            </a>
          </div>
        </div>
      </div>

      <div class="contact-form-card" data-tilt>
        <div class="form-glow"></div>
        
        <div class="form-header">
          <h3>Send Me a Message</h3>
          <p>Fill out the form below and I'll get back to you as soon as possible.</p>
        </div>

        <form id="contactForm" action="https://formspree.io/f/mykpzlag" method="POST" class="contact-form">
          <input type="hidden" name="_subject" value="New message from portfolio!">

          <div class="form-group">
            <label class="form-label" for="name">
              Your Name <span class="required">*</span>
            </label>
            <div class="input-wrapper">
              <i class="bi bi-person input-icon"></i>
              <input type="text" id="name" name="name" class="form-input" placeholder="John Doe" required />
            </div>
            <span class="error-message">Please enter your name</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="email">
              Your Email <span class="required">*</span>
            </label>
            <div class="input-wrapper">
              <i class="bi bi-envelope input-icon"></i>
              <input type="email" id="email" name="email" class="form-input" placeholder="john@example.com" required />
            </div>
            <span class="error-message">Please enter a valid email</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="subject">
              Subject <span class="required">*</span>
            </label>
            <div class="input-wrapper">
              <i class="bi bi-chat-left-text input-icon"></i>
              <select id="subject" name="subject" class="form-input form-select" required>
                <option value="" disabled selected>Select a subject...</option>
                <option value="project">Project Collaboration</option>
                <option value="job">Job Opportunity</option>
                <option value="freelance">Freelance Work</option>
                <option value="mentorship">Mentorship</option>
                <option value="other">Other</option>
              </select>
            </div>
            <span class="error-message">Please select a subject</span>
          </div>

          <div class="form-group">
            <label class="form-label" for="message">
              Your Message <span class="required">*</span>
            </label>
            <div class="input-wrapper textarea-wrapper">
              <textarea id="message" name="message" class="form-textarea" placeholder="Tell me about your project, idea, or opportunity..." rows="4" maxlength="1000" required></textarea>
              <div class="char-counter">
                <span id="charCount">0</span> / 1000
              </div>
            </div>
            <span class="error-message">Please enter your message</span>
          </div>

          <button type="submit" class="submit-btn" id="submitBtn">
            <span class="btn-text">Send Message</span>
            <i class="bi bi-send-fill btn-icon"></i>
            <span class="btn-loader" style="display: none;">
              <span class="spinner"></span>
              <span>Sending...</span>
            </span>
          </button>
        </form>

        <div class="form-message success" id="successMessage" style="display: none;">
          <div class="message-icon">
            <i class="bi bi-check-circle-fill"></i>
          </div>
          <div class="message-content">
            <h4>Message Sent!</h4>
            <p>Thank you for reaching out. I'll get back to you within 24 hours.</p>
          </div>
        </div>

        <div class="form-message error" id="errorMessage" style="display: none;">
          <div class="message-icon">
            <i class="bi bi-x-circle-fill"></i>
          </div>
          <div class="message-content">
            <h4>Oops!</h4>
            <p>Something went wrong. Please try again or email me directly.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="toast-notification" id="toastNotification">
    <i class="bi bi-check-circle-fill"></i>
    <span id="toastMessage">Email copied to clipboard!</span>
  </div>
</section>

<script>
  import '../scripts/contact.js';
</script>

<script is:global>
  function copyContactEmail(email, element) {
    navigator.clipboard.writeText(email).then(() => {
      const icon = element.querySelector('#copyIcon');
      if (icon) {
        icon.className = 'bi bi-check2';
        icon.style.color = '#22c55e';
        
        setTimeout(() => {
          icon.className = 'bi bi-clipboard';
          icon.style.color = '';
        }, 2000);
      }
      
      const toast = document.getElementById('toastNotification');
      const toastMessage = document.getElementById('toastMessage');
      toastMessage.textContent = 'Email copied to clipboard!';
      toast.style.background = '#22c55e';
      toast.classList.add('show');
      
      element.style.borderColor = '#22c55e';
      setTimeout(() => {
        element.style.borderColor = '';
      }, 2000);
      
      setTimeout(() => {
        toast.classList.remove('show');
      }, 3000);
    }).catch(err => {
      console.error('Failed to copy:', err);
    });
  }
</script>
